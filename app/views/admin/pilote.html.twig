{% extends 'layout/base.html.twig' %}

{% block title %}
{% if action == 'voir' and pilot.id %}
Fiche pilote - StageHub
{% elseif action == 'creer' %}
Ajouter un pilote - StageHub
{% elseif action == 'modifier' %}
Modifier un pilote - StageHub
{% elseif action == 'supprimer' %}
Supprimer un pilote - StageHub
{% else %}
Gestion des pilotes - StageHub
{% endif %}
{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="{{ base_url }}css/admin.css?v=5">
{% endblock %}

{% block content %}
<section class="admin-dashboard">
    <div class="admin-hero">
        <div>
            <span class="admin-kicker">Espace administration</span>
            {% if action == 'liste' %}
                <h1>Gestion des pilotes</h1>
                <p>Recherchez, creez, modifiez ou supprimez les comptes pilotes de la plateforme.</p>
            {% elseif action == 'voir' and pilot.id %}
                <h1>{{ pilot.prenom }} {{ pilot.nom }}</h1>
                <p>Fiche detaillee du pilote et acces rapides pour la gestion du compte.</p>
            {% elseif action == 'creer' %}
                <h1>Ajouter un pilote</h1>
                <p>Remplissez le formulaire pour creer un nouveau compte pilote.</p>
            {% elseif action == 'modifier' and pilot.id %}
                <h1>Modifier un pilote</h1>
                <p>Mettez a jour les informations de {{ pilot.prenom }} {{ pilot.nom }}.</p>
            {% elseif action == 'supprimer' and pilot.id %}
                <h1>Supprimer un pilote</h1>
                <p>Cette action est irreversible. Verifiez les informations avant de confirmer.</p>
            {% endif %}
        </div>

        <div class="admin-hero-actions">
            {% if action == 'liste' %}
                <a href="{{ base_url }}admin/pilotes?action=creer" class="admin-btn admin-btn-primary">
                    <i class="bi bi-person-plus-fill"></i>
                    Ajouter un pilote
                </a>
                <a href="{{ base_url }}admin" class="admin-btn admin-btn-secondary">
                    <i class="bi bi-arrow-left"></i>
                    Retour au dashboard
                </a>
            {% elseif action == 'voir' and pilot.id %}
                <a href="{{ base_url }}admin/pilotes?action=modifier&id={{ pilot.id }}" class="admin-btn admin-btn-primary">
                    <i class="bi bi-pencil-fill"></i>
                    Modifier
                </a>
                <a href="{{ base_url }}admin/pilotes" class="admin-btn admin-btn-secondary">
                    <i class="bi bi-arrow-left"></i>
                    Retour a la liste
                </a>
            {% else %}
                <a href="{{ base_url }}admin/pilotes" class="admin-btn admin-btn-secondary">
                    <i class="bi bi-arrow-left"></i>
                    Retour a la liste
                </a>
            {% endif %}
        </div>
    </div>

    {% if pilotFlash %}
        <div class="admin-alert admin-alert-{{ pilotFlash.type }}">
            {{ pilotFlash.message }}
        </div>
    {% endif %}

    {% if formErrors is not empty %}
        <div class="admin-alert admin-alert-error">
            <ul style="margin: 0; padding-left: 1.2rem;">
                {% for error in formErrors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {% if action == 'liste' %}
        <section class="admin-panel">
            <div class="admin-panel-head">
                <div>
                    <span class="admin-panel-kicker">Recherche</span>
                    <h2>Filtrer les pilotes</h2>
                </div>
            </div>

            <form method="GET" action="{{ base_url }}admin/pilotes" class="admin-search-bar">
                <input type="hidden" name="action" value="liste">
                <input type="text" name="q" value="{{ search }}" placeholder="Nom, prenom ou email..." class="admin-search-input">
                <button type="submit" class="admin-btn admin-btn-primary admin-btn-sm">
                    <i class="bi bi-search"></i>
                    Rechercher
                </button>
                {% if search %}
                    <a href="{{ base_url }}admin/pilotes" class="admin-btn admin-btn-secondary admin-btn-sm">
                        <i class="bi bi-x-lg"></i>
                        Reinitialiser
                    </a>
                {% endif %}
            </form>
        </section>

        <section class="admin-panel">
            <div class="admin-panel-head">
                <div>
                    <span class="admin-panel-kicker">Pilotes</span>
                    <h2>{{ pilotes|length }} compte(s) pilote</h2>
                </div>
            </div>

            {% if pilotes is empty %}
                <p class="admin-empty">Aucun pilote trouve.</p>
            {% else %}
                <div class="admin-table-wrap">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Nom</th>
                                <th>Email</th>
                                <th>Cree le</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for pilote in pilotes %}
                                <tr>
                                    <td>
                                        <strong>{{ pilote.prenom }} {{ pilote.nom }}</strong>
                                        <div class="admin-table-subline">Compte pilote</div>
                                    </td>
                                    <td>{{ pilote.email }}</td>
                                    <td>
                                        {% if pilote.created_at %}
                                            {{ pilote.created_at|date('d/m/Y H:i') }}
                                        {% else %}
                                            Non renseigne
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="admin-actions-wrap">
                                            <a href="{{ base_url }}admin/pilotes?action=voir&id={{ pilote.id }}" class="admin-btn admin-btn-muted admin-btn-sm">
                                                <i class="bi bi-eye"></i>
                                                Voir
                                            </a>
                                            <a href="{{ base_url }}admin/pilotes?action=modifier&id={{ pilote.id }}" class="admin-btn admin-btn-muted admin-btn-sm">
                                                <i class="bi bi-pencil-fill"></i>
                                                Modifier
                                            </a>
                                            <a href="{{ base_url }}admin/pilotes?action=supprimer&id={{ pilote.id }}" class="admin-btn admin-btn-danger admin-btn-sm">
                                                <i class="bi bi-trash-fill"></i>
                                                Supprimer
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </section>
    {% elseif action == 'voir' and pilot.id %}
        <div class="admin-grid">
            <section class="admin-panel">
                <div class="admin-panel-head">
                    <div>
                        <span class="admin-panel-kicker">Profil</span>
                        <h2>Informations du pilote</h2>
                    </div>
                </div>

                <div class="admin-summary-list">
                    <div class="admin-summary-row">
                        <span class="admin-summary-label">Prenom</span>
                        <strong>{{ pilot.prenom }}</strong>
                    </div>
                    <div class="admin-summary-row">
                        <span class="admin-summary-label">Nom</span>
                        <strong>{{ pilot.nom }}</strong>
                    </div>
                    <div class="admin-summary-row">
                        <span class="admin-summary-label">Email</span>
                        <strong>{{ pilot.email }}</strong>
                    </div>
                    <div class="admin-summary-row">
                        <span class="admin-summary-label">Role</span>
                        <span class="admin-role-pill admin-role-pilote">Pilote</span>
                    </div>
                    <div class="admin-summary-row">
                        <span class="admin-summary-label">Cree le</span>
                        <strong>
                            {% if pilot.created_at %}
                                {{ pilot.created_at|date('d/m/Y H:i') }}
                            {% else %}
                                Non renseigne
                            {% endif %}
                        </strong>
                    </div>
                </div>
            </section>

            <section class="admin-panel">
                <div class="admin-panel-head">
                    <div>
                        <span class="admin-panel-kicker">Actions</span>
                        <h2>Gestion rapide</h2>
                    </div>
                </div>

                <div class="admin-summary-list">
                    <div class="admin-summary-row">
                        <span class="admin-summary-label">Modifier la fiche</span>
                        <a href="{{ base_url }}admin/pilotes?action=modifier&id={{ pilot.id }}" class="admin-btn admin-btn-primary admin-btn-sm">
                            Modifier
                        </a>
                    </div>
                    <div class="admin-summary-row">
                        <span class="admin-summary-label">Supprimer le compte</span>
                        <a href="{{ base_url }}admin/pilotes?action=supprimer&id={{ pilot.id }}" class="admin-btn admin-btn-danger admin-btn-sm">
                            Supprimer
                        </a>
                    </div>
                </div>
            </section>
        </div>
    {% elseif action in ['creer', 'modifier'] %}
        <section class="admin-panel">
            <div class="admin-panel-head">
                <div>
                    <span class="admin-panel-kicker">Formulaire</span>
                    <h2>{% if action == 'creer' %}Nouveau pilote{% else %}Mettre a jour le compte{% endif %}</h2>
                </div>
            </div>

            <form method="POST" action="{{ base_url }}admin/pilotes">
                <input type="hidden" name="csrf_token" value="{{ session.csrf_token }}">
                <input type="hidden" name="action" value="{{ action }}">
                {% if action == 'modifier' and pilot.id %}
                    <input type="hidden" name="id" value="{{ pilot.id }}">
                {% endif %}

                <div class="admin-form-grid">
                    <div class="admin-form-group">
                        <label for="pilot-prenom">Prenom</label>
                        <input type="text" id="pilot-prenom" name="prenom" required value="{{ pilotForm.prenom }}" placeholder="Prenom">
                    </div>
                    <div class="admin-form-group">
                        <label for="pilot-nom">Nom</label>
                        <input type="text" id="pilot-nom" name="nom" required value="{{ pilotForm.nom }}" placeholder="Nom">
                    </div>
                    <div class="admin-form-group">
                        <label for="pilot-email">Email</label>
                        <input type="email" id="pilot-email" name="email" required value="{{ pilotForm.email }}" placeholder="email@exemple.com">
                    </div>
                    <div class="admin-form-group">
                        <label for="pilot-password">
                            {% if action == 'creer' %}
                                Mot de passe
                            {% else %}
                                Nouveau mot de passe
                            {% endif %}
                        </label>
                        <input type="password" id="pilot-password" name="password" {% if action == 'creer' %}required{% endif %} minlength="8" placeholder="{% if action == 'creer' %}Min. 8 caracteres{% else %}Laisser vide pour conserver l'ancien{% endif %}">
                    </div>
                </div>

                <div class="admin-form-actions">
                    <a href="{{ base_url }}admin/pilotes{% if action == 'modifier' and pilot.id %}?action=voir&id={{ pilot.id }}{% endif %}" class="admin-btn admin-btn-secondary">
                        Annuler
                    </a>
                    <button type="submit" class="admin-btn admin-btn-primary">
                        <i class="bi bi-check-lg"></i>
                        {% if action == 'creer' %}Creer le pilote{% else %}Enregistrer les modifications{% endif %}
                    </button>
                </div>
            </form>
        </section>
    {% elseif action == 'supprimer' and pilot.id %}
        <section class="admin-panel">
            <div class="admin-panel-head">
                <div>
                    <span class="admin-panel-kicker">Confirmation</span>
                    <h2>Supprimer ce compte pilote</h2>
                </div>
            </div>

            <div class="admin-summary-list">
                <div class="admin-summary-row">
                    <span class="admin-summary-label">Pilote</span>
                    <strong>{{ pilot.prenom }} {{ pilot.nom }}</strong>
                </div>
                <div class="admin-summary-row">
                    <span class="admin-summary-label">Email</span>
                    <strong>{{ pilot.email }}</strong>
                </div>
                <div class="admin-summary-row">
                    <span class="admin-summary-label">Role</span>
                    <span class="admin-role-pill admin-role-pilote">Pilote</span>
                </div>
            </div>

            <form method="POST" action="{{ base_url }}admin/pilotes" style="margin-top: 1.5rem;">
                <input type="hidden" name="csrf_token" value="{{ session.csrf_token }}">
                <input type="hidden" name="action" value="supprimer_ok">
                <input type="hidden" name="id" value="{{ pilot.id }}">

                <div class="admin-form-actions">
                    <a href="{{ base_url }}admin/pilotes?action=voir&id={{ pilot.id }}" class="admin-btn admin-btn-secondary">
                        Annuler
                    </a>
                    <button type="submit" class="admin-btn admin-btn-danger">
                        <i class="bi bi-trash-fill"></i>
                        Confirmer la suppression
                    </button>
                </div>
            </form>
        </section>
    {% endif %}
</section>
{% endblock %}