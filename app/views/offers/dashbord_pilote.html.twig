{% extends 'layout/base.html.twig' %}

{% block title %}Dashboard Pilote - StageHub{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="{{ base_url }}css/dashboard-pilote.css?v=2">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
{% endblock %}

{% block content %}

<h1>Dashboard Pilote</h1>

<!-- HERO -->
<div class="hero">
    <div style="font-size:11px; color:#40c057; font-weight:700; margin-bottom:6px;">
        <i class="bi bi-circle-fill" style="font-size:8px;"></i> Session active
    </div>
    <p class="hero-sub">Pilote · {{ pilote.prenom }} {{ pilote.nom }}</p>
    <span class="hero-badge">PILOTE DE PROMOTION</span>
</div>

<!-- STATS -->
<div class="stats-grid">
    {% for s in stats %}
        <div class="stat-card {{ s.cls }}">
            <div>{{ s.icon|raw }}</div>
            <div class="stat-val">{{ s.val }}</div>
            <div class="stat-lbl">{{ s.lbl }}</div>
            <div class="stat-delta" style="color:{{ s.color }}">
                {{ s.delta }}
            </div>
        </div>
    {% endfor %}
</div>

<!-- SUIVI ÉTUDIANTS -->
<div class="card">
    <div class="card-head">
        <span class="card-title">Suivi étudiants</span>
        <a href="{{ base_url }}admin/etudiants" class="see-all">Gérer les étudiants →</a>
    </div>

    {% for e in etudiants %}
        <div class="row">
            <div style="display:flex; align-items:center; gap:8px;">
                <div class="avatar">{{ e.initiale }}</div>
                <div>
                    <div style="font-weight:600; font-size:12px;">{{ e.nom }}</div>
                    <div style="color:var(--muted); font-size:10px;">
                        {{ e.cand }} candidature{{ e.cand > 1 ? 's' : '' }}
                    </div>
                </div>
            </div>
            <span class="badge {{ e.badge }}">{{ e.statut }}</span>
        </div>
    {% endfor %}
</div>

<!-- GRAPHIQUE -->
<div class="card">
    <div class="card-head">
        <span class="card-title">Candidatures / mois</span>
        <span class="badge badge-purple">2024–25</span>
    </div>
    <div class="chart-wrap">
        {% for h in [25, 46, 36, 66, 57, 100] %}
            <div class="chart-bar" style="height:{{ h }}%"></div>
        {% endfor %}
    </div>
    <div class="chart-labels">
        {% for m in ['Oct', 'Nov', 'Déc', 'Jan', 'Fév', 'Mar'] %}
            <span>{{ m }}</span>
        {% endfor %}
    </div>
    <div style="margin-top:14px;">
        {% for b in barres %}
            <div class="bar-wrap">
                <div class="bar-label">
                    <span>{{ b.lbl }}</span>
                    <span style="font-weight:700; color:{{ b.color }}">{{ b.val }}</span>
                </div>
                <div class="bar-track">
                    <div class="bar-fill" style="width:{{ b.pct }}%; background:{{ b.color }};"></div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>

<!-- CANDIDATURES RÉCENTES -->
<div class="card">
    <div class="card-head">
        <span class="card-title">Candidatures récentes</span>
        <a href="#" class="see-all">Voir toutes →</a>
    </div>

    <fieldset>
        <legend class="sr-only">Rechercher une candidature</legend>
        <div class="form-group">
            <label for="search">Rechercher</label>
            <input type="text" id="search" name="search" placeholder="Étudiant, entreprise…">
        </div>
        <button type="submit" class="btn-submit"><i class="bi bi-search"></i> Rechercher</button>
    </fieldset>

    {% for c in candidatures %}
        <div class="cand-row">
            <div style="display:flex; align-items:center; gap:10px;">
                <div class="avatar">{{ c.initiale }}</div>
                <div>
                    <div style="font-weight:700; font-size:12px;">{{ c.nom }}</div>
                    <div class="company">{{ c.poste }} · {{ c.entreprise }}</div>
                    <div style="color:var(--muted); font-size:10px;">📅 {{ c.date }}</div>
                </div>
            </div>
            <div style="display:flex; flex-direction:column; align-items:flex-end; gap:5px;">
                <span class="badge {{ c.badge }}">{{ c.statut }}</span>
                <div style="display:flex; gap:4px;">
                    <button type="button" class="btn-ghost"><i class="bi bi-file-earmark-person"></i> CV</button>
                    <button type="button" class="btn-ghost"><i class="bi bi-file-earmark-text"></i> LM</button>
                </div>
            </div>
        </div>
    {% endfor %}
</div>

<!-- ACTIVITÉ RÉCENTE -->
<div class="card">
    <div class="card-head">
        <span class="card-title">Activité récente</span>
    </div>
    {% for a in activites %}
        <div class="act">
            <div class="act-dot" style="background:{{ a.dot }};"></div>
            <div>
                <div>{{ a.txt }}</div>
                <div style="color:var(--muted); margin-top:2px;">{{ a.time }}</div>
            </div>
        </div>
    {% endfor %}
</div>

{% endblock %}
